{
	"name": "n8n-nodes-albacross",
	"version": "0.1.1",
	"description": "n8n community node for Albacross — receive identified-company leads in your n8n workflows.",
	"license": "MIT",
	"homepage": "https://github.com/albacross/n8n-nodes-albacross",
	"keywords": [
		"n8n-community-node-package",
		"albacross",
		"leads",
		"intent"
	],
	"author": {
		"name": "Albacross",
		"email": "developers@albacross.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/albacross/n8n-nodes-albacross.git"
	},
	"engines": {
		"node": ">=20.15"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"test": "jest"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AlbacrossApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/AlbacrossTrigger/AlbacrossTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.28.0",
		"@types/jest": "^29.5.12",
		"eslint": "9.32.0",
		"jest": "^29.7.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"ts-jest": "^29.1.5",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
